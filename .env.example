# Copy this file to .env and fill in real values
PORT=3000

# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=1h

# External lottery API
LOTTERY_API_URL=https://api.luckydraw.io/v1

# Cache TTL in seconds (default for all cache entries)
CACHE_TTL=60

# TTL in seconds for lottery API responses (tickets, draws, winnings)
LOTTERY_CACHE_TTL=15

# Logging level (trace | debug | info | warn | error)
LOG_LEVEL=info

# Max login attempts per IP per 15 minutes
LOGIN_RATE_LIMIT=10

# Bcrypt password hashes for users (generate with: node -e "require('bcrypt').hash('yourpassword',10).then(console.log)")
ADMIN_PASSWORD_HASH=
JOHN_PASSWORD_HASH=
